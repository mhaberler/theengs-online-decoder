# Settings consumed by scripts/deploy-web.sh.
# Copy to .env (gitignored) and fill in. Process-env overrides win.

DEPLOY_HOST=user@example.com
DEPLOY_PATH=/toplevel/apps/theengs-decoder/
DEPLOY_BASE=/apps/theengs-decoder/
DEPLOY_URL=https://example.com/apps/theengs-decoder/

# Optional. Only set if sshd on the target listens on a non-default port.
# DEPLOY_PORT=22


